# Example environment variables. This file IS committed.
# Copy it to .env (local, NOT committed – see .gitignore) and fill in real values.

# === OpenAI / Azure OpenAI ===
OPENAI_API_KEY=sk-...
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# === Database ===
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# === App ===
APP_ENV=development
LOG_LEVEL=INFO
PORT=8000
